# .env.test.example — copy to .env.test and fill in values before running the test suite
# .env.test is gitignored; never commit secrets.

# Cerebras API key for live test suite (paid tier — used by run_quality_tests.py)
CEREBRAS_API_KEY=

# Base URL of the dev deployment (defaults to https://med.debkay.com if not set)
TEST_BASE_URL=https://med.debkay.com

# Optional: Firebase ID token for authenticated endpoint tests
# Obtain via: firebase auth:token in the Firebase CLI, or from browser devtools
TEST_FIREBASE_ID_TOKEN=
