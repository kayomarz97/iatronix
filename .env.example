DATABASE_URL=postgresql+asyncpg://medadmin:CHANGE_ME@iatronix-db:5432/medvectordb
POSTGRES_DB=medvectordb
POSTGRES_USER=medadmin
POSTGRES_PASSWORD=CHANGE_ME
REDIS_URL=redis://iatronix-redis:6379/0
INTERNAL_API_URL=http://iatronix-backend:8000
ALLOWED_ORIGINS=http://localhost:3200
SENTRY_DSN=
PROMPT_VERSION=3
API_FETCH_ENABLED=true
MODEL_ROUTING_ENABLED=true
# Anthropic Claude model IDs — override here without code changes
# If you get a "Model does not exist" error, update these to valid model IDs from your Anthropic plan
MODEL_HAIKU=claude-haiku-4-5-20251001
MODEL_SONNET=claude-sonnet-4-20250514
MODEL_CLASSIFY=claude-haiku-4-5-20251001
MODEL_GENERATE=claude-haiku-4-5-20251001
DSPY_ENABLED=true
ADAPTIVE_SECOND_PASS_ENABLED=true
FAIL_CLOSED_EVIDENCE_ONLY=true
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_THRESHOLD=0.92
ENCRYPTION_KEY=CHANGE_ME
FLUSH_REDIS=0
PARALLEL_SECTIONS_ENABLED=true
CITATION_REF_TOKENS_ENABLED=true
PUBMED_EXPANSION_ENABLED=true
SNOWBALL_ENABLED=true
SNOWBALL_MAX_REFS=15
# OpenRouter OAuth PKCE
OPENROUTER_CALLBACK_BASE=https://med.debkay.com
OPENROUTER_GEMMA_PRIMARY=google/gemma-4-31b-it
OPENROUTER_GEMMA_FALLBACK=google/gemma-4-26b-a4b-it:free
# Cerebras (paid tier, OpenAI-compatible)
CEREBRAS_DEFAULT_MODEL=gpt-oss-120b
# CEREBRAS_API_BASE=https://api.cerebras.ai/v1  # rarely needs changing
# Note: NEXT_PUBLIC_CEREBRAS_MODEL is no longer used — model identity is served via /api/v1/config/llm

# ── Provider-agnostic refactor flags ──
# Providers/models are now defined in backend/config/providers.yaml (single source of truth).
# KeyStore: where BYOK keys live. Postgres is authoritative; Firestore is an optional
# server-side (Admin SDK) mirror for easy migration. Flip primary once mirrored.
KEYSTORE_PRIMARY=postgres                 # postgres | firestore
KEYSTORE_FIRESTORE_ENABLED=false          # dual-write keys to Firestore when true
# Deep-grounded citation chasing (bounds in providers.yaml deep_search). Off until verified.
DEEP_SEARCH_ENABLED=false
# Horizontal scaling: gunicorn workers per backend replica (also set in compose).
GUNICORN_WORKERS=4
